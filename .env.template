# === Avicenna Configuration ===
#
# Zero-config defaults: everything runs locally, no API keys, no Ollama needed.
# FastEmbed handles embeddings on CPU. Just install and go.

# Embeddings — FastEmbed (local, CPU-only, no API key)
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384
HUGGINGFACE_TOKENIZER=sentence-transformers/all-MiniLM-L6-v2

# Storage (all file-based, no external services)
VECTOR_DB_PROVIDER=lancedb
GRAPH_DATABASE_PROVIDER=kuzu
DB_PROVIDER=sqlite

# Avicenna Settings
AVICENNA_DATA_DIR=~/.avicenna
AVICENNA_MAX_FILE_SIZE_KB=500
AVICENNA_BATCH_SIZE=50

# --- Optional: LLM for advanced graph search ---
# By default, no LLM is used. Avicenna relies on vector search (embeddings)
# which Claude then reasons over. If you want GRAPH_COMPLETION search
# (LLM-powered graph traversal), configure one of these:
#
# Option A: Ollama (local, free)
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.1:8b
# LLM_ENDPOINT=http://localhost:11434/v1
# LLM_API_KEY=ollama
#
# Option B: OpenAI (cloud, paid)
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-your-key-here

# --- Optional: Alternative embedding providers ---
#
# Option A: Ollama (local, requires Ollama running)
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text:latest
# EMBEDDING_ENDPOINT=http://localhost:11434/api/embed
# EMBEDDING_DIMENSIONS=768
# HUGGINGFACE_TOKENIZER=nomic-ai/nomic-embed-text-v1.5
#
# Option B: OpenAI (cloud, paid, higher quality)
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536
# EMBEDDING_API_KEY=sk-your-key-here
