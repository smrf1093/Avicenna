---
const comparisons = [
  {
    task: "Finding a function",
    before: { method: "3-5 grep calls + 2-3 file reads", tokens: "~4,000" },
    after: { method: "1 find_symbol call", tokens: "~400" },
  },
  {
    task: "Understanding dependencies",
    before: { method: "grep imports + read 4 files", tokens: "~6,000" },
    after: { method: "1 get_dependencies call", tokens: "~600" },
  },
  {
    task: "Exploring a module",
    before: { method: "ls + read 5 files", tokens: "~10,000" },
    after: { method: "1 get_file_summary call", tokens: "~500" },
  },
];
---

<section id="metrics" class="py-20 bg-bg-primary">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Token Savings</h2>
      <p class="text-text-secondary text-lg max-w-2xl mx-auto">
        Real metrics from actual usage — not theoretical estimates.
      </p>
    </div>

    <!-- Big stat -->
    <div class="text-center mb-14">
      <div class="text-6xl md:text-8xl font-bold text-accent-green mb-2">86.6%</div>
      <p class="text-text-secondary text-lg">Token savings measured over 7 days of real use</p>
    </div>

    <!-- Stats terminal -->
    <div class="max-w-lg mx-auto mb-14">
      <div class="rounded-xl border border-border overflow-hidden">
        <div class="flex items-center gap-2 px-4 py-3 bg-bg-secondary border-b border-border">
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
          </div>
          <span class="text-xs text-text-muted ml-2 font-mono">avicenna stats</span>
        </div>
        <pre class="p-5 bg-bg-secondary/50 text-sm leading-relaxed"><code><span class="text-accent-cyan">===</span> <span class="text-text-primary">Avicenna Token Savings Report</span> <span class="text-accent-cyan">===</span>

  <span class="text-text-muted">Period:</span>            <span class="text-text-primary">Last 7 day(s)</span>
  <span class="text-text-muted">Total tool calls:</span>  <span class="text-text-primary">47</span>
  <span class="text-text-muted">Avicenna tokens:</span>   <span class="text-accent-green">3,842</span>
  <span class="text-text-muted">Traditional est.:</span>  <span class="text-accent-amber">28,650</span>
  <span class="text-text-muted">Tokens saved:</span>      <span class="text-accent-green font-semibold">24,808</span>
  <span class="text-text-muted">Savings:</span>           <span class="text-accent-green font-bold">86.6%</span></code></pre>
      </div>
    </div>

    <!-- Before/After comparison -->
    <div class="max-w-4xl mx-auto">
      <h3 class="text-xl font-semibold text-center mb-6">Task-by-Task Comparison</h3>
      <div class="space-y-4">
        {comparisons.map((item) => (
          <div class="grid grid-cols-1 md:grid-cols-[1fr_1fr_1fr] gap-4 bg-bg-card rounded-lg p-5 border border-border">
            <div>
              <span class="text-xs text-text-muted uppercase tracking-wider">Task</span>
              <p class="text-sm font-semibold mt-1">{item.task}</p>
            </div>
            <div class="border-t md:border-t-0 md:border-l border-border md:pl-4 pt-3 md:pt-0">
              <span class="text-xs text-accent-amber uppercase tracking-wider">Without Avicenna</span>
              <p class="text-sm text-text-secondary mt-1">{item.before.method}</p>
              <p class="text-sm font-mono font-semibold text-accent-amber mt-1">{item.before.tokens} tokens</p>
            </div>
            <div class="border-t md:border-t-0 md:border-l border-border md:pl-4 pt-3 md:pt-0">
              <span class="text-xs text-accent-green uppercase tracking-wider">With Avicenna</span>
              <p class="text-sm text-text-secondary mt-1">{item.after.method}</p>
              <p class="text-sm font-mono font-semibold text-accent-green mt-1">{item.after.tokens} tokens</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
