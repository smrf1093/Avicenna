---
const links = [
  { label: "Features", href: "#features" },
  { label: "Tools", href: "#tools" },
  { label: "Skills", href: "#skills" },
  { label: "Quick Start", href: "#quickstart" },
  { label: "Metrics", href: "#metrics" },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-bg-primary/80 backdrop-blur-md border-b border-border">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="#" class="flex items-center gap-2 text-lg font-bold">
      <svg class="w-6 h-6" viewBox="0 0 32 32" fill="none">
        <circle cx="16" cy="8" r="3" fill="#3b82f6" />
        <circle cx="8" cy="22" r="3" fill="#8b5cf6" />
        <circle cx="24" cy="22" r="3" fill="#06b6d4" />
        <line x1="16" y1="11" x2="8" y2="19" stroke="#3b82f6" stroke-width="1.5" stroke-linecap="round" />
        <line x1="16" y1="11" x2="24" y2="19" stroke="#06b6d4" stroke-width="1.5" stroke-linecap="round" />
        <line x1="8" y1="22" x2="24" y2="22" stroke="#8b5cf6" stroke-width="1.5" stroke-linecap="round" />
      </svg>
      <span class="bg-gradient-to-r from-accent-blue to-accent-purple bg-clip-text text-transparent">
        Avicenna
      </span>
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          class="text-sm text-text-secondary hover:text-text-primary transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://github.com/smrf1093/Avicenna"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-sm text-text-secondary hover:text-text-primary transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
        </svg>
        GitHub
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="Toggle menu"
    >
      <span class="w-5 h-0.5 bg-text-secondary transition-transform" id="bar1"></span>
      <span class="w-5 h-0.5 bg-text-secondary transition-opacity" id="bar2"></span>
      <span class="w-5 h-0.5 bg-text-secondary transition-transform" id="bar3"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-border bg-bg-primary/95 backdrop-blur-md"
  >
    <div class="px-6 py-4 flex flex-col gap-4">
      {links.map((link) => (
        <a
          href={link.href}
          class="text-sm text-text-secondary hover:text-text-primary transition-colors mobile-link"
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://github.com/smrf1093/Avicenna"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-text-secondary hover:text-text-primary transition-colors"
      >
        GitHub
      </a>
    </div>
  </div>
</nav>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
  document.querySelectorAll(".mobile-link").forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
    });
  });
</script>
