---

---

<footer class="bg-bg-secondary border-t border-border py-12">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex flex-col items-center text-center">
      <!-- Logo -->
      <div class="flex items-center gap-2 mb-4">
        <svg class="w-6 h-6" viewBox="0 0 32 32" fill="none">
          <circle cx="16" cy="8" r="3" fill="#3b82f6" />
          <circle cx="8" cy="22" r="3" fill="#8b5cf6" />
          <circle cx="24" cy="22" r="3" fill="#06b6d4" />
          <line x1="16" y1="11" x2="8" y2="19" stroke="#3b82f6" stroke-width="1.5" stroke-linecap="round" />
          <line x1="16" y1="11" x2="24" y2="19" stroke="#06b6d4" stroke-width="1.5" stroke-linecap="round" />
          <line x1="8" y1="22" x2="24" y2="22" stroke="#8b5cf6" stroke-width="1.5" stroke-linecap="round" />
        </svg>
        <span class="text-lg font-bold text-text-primary">Avicenna</span>
      </div>

      <p class="text-text-secondary text-sm mb-6">
        Code knowledge graph for Claude CLI
      </p>

      <!-- Links -->
      <div class="flex items-center gap-6 mb-8">
        <a
          href="https://github.com/smrf1093/Avicenna"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-text-secondary hover:text-accent-blue transition-colors"
        >
          GitHub
        </a>
        <span class="text-border">|</span>
        <a
          href="https://github.com/smrf1093/Avicenna/blob/main/README.md"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-text-secondary hover:text-accent-blue transition-colors"
        >
          Documentation
        </a>
        <span class="text-border">|</span>
        <span class="text-sm text-text-secondary">MIT License</span>
      </div>

      <!-- Built with -->
      <div class="mb-6">
        <p class="text-text-muted text-xs mb-2">Built with</p>
        <div class="flex flex-wrap justify-center gap-2">
          {["Cognee", "tree-sitter", "FastMCP", "FastEmbed", "LanceDB", "Kuzu"].map((tech) => (
            <span class="px-2 py-1 rounded text-xs bg-bg-card border border-border text-text-muted">
              {tech}
            </span>
          ))}
        </div>
      </div>

      <p class="text-text-muted text-xs">
        Made for the Claude CLI ecosystem
      </p>
    </div>
  </div>
</footer>
