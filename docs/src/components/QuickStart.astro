---
function formatCode(code: string): string {
  return code
    .split("\n")
    .map((line) =>
      line
        ? `<span class="text-accent-cyan">$</span> <span class="text-text-primary">${line}</span>`
        : ""
    )
    .join("\n");
}

const steps = [
  {
    number: "1",
    title: "Install as Plugin (Recommended)",
    code: `/plugin install avicenna@claude-plugins-official`,
    note: "Run this inside Claude Code. That's it — Avicenna tools are immediately available in all your projects.",
  },
  {
    number: "2",
    title: "Or Install from Source",
    code: `git clone https://github.com/smrf1093/Avicenna.git
cd Avicenna
python -m venv .venv && source .venv/bin/activate
pip install -e .
python -m avicenna init /path/to/your/project`,
    note: "Registers the MCP server, indexes your codebase, and creates a CLAUDE.md — all in one command.",
  },
  {
    number: "3",
    title: "Use",
    code: `cd /path/to/your/project && claude`,
    note: "Avicenna tools are now available. Try asking Claude to search your code or analyze dependencies.",
  },
];
---

<section id="quickstart" class="py-20 bg-bg-primary">
  <div class="max-w-4xl mx-auto px-6">
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Get Started in 60 Seconds</h2>
      <p class="text-text-secondary text-lg max-w-2xl mx-auto">
        Zero config. No API keys. Just install, init, and go.
      </p>
    </div>

    <div class="space-y-8">
      {steps.map((step) => (
        <div class="flex gap-5">
          <!-- Step number -->
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-accent-blue/10 border border-accent-blue/20 flex items-center justify-center">
            <span class="text-accent-blue font-bold text-lg">{step.number}</span>
          </div>

          <div class="flex-1 min-w-0">
            <h3 class="text-lg font-semibold mb-3">{step.title}</h3>

            <!-- Code block -->
            <div class="rounded-lg border border-border overflow-hidden">
              <div class="flex items-center gap-2 px-4 py-2 bg-bg-secondary border-b border-border">
                <div class="flex gap-1.5">
                  <div class="w-2 h-2 rounded-full bg-red-500/60"></div>
                  <div class="w-2 h-2 rounded-full bg-yellow-500/60"></div>
                  <div class="w-2 h-2 rounded-full bg-green-500/60"></div>
                </div>
              </div>
              <pre class="p-4 bg-bg-secondary/50 text-sm leading-relaxed overflow-x-auto"><code set:html={formatCode(step.code)} /></pre>
            </div>

            {step.note && (
              <p class="text-text-secondary text-sm mt-3">{step.note}</p>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- Supported languages -->
    <div class="mt-14 text-center">
      <p class="text-text-muted text-sm mb-3">Supported languages</p>
      <div class="flex justify-center gap-3">
        {["Python", "TypeScript", "JavaScript"].map((lang) => (
          <span class="px-3 py-1.5 rounded-lg text-sm font-medium bg-bg-card border border-border text-text-secondary">
            {lang}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
